{
  "version": 2,
  "functions": {
    "api/index.js": {
      "runtime": "nodejs18.x",
      "maxDuration": 30
    }
  },
  "routes": [
    {
      "src": "/",
      "dest": "/api/index.js"
    },
    {
      "src": "/api/(.*)",
      "dest": "/api/index.js"
    },
    {
      "src": "/api/gen",
      "dest": "/api/index.js"
    },
    {
      "src": "/api/gen/image",
      "dest": "/api/index.js"
    },
    {
      "src": "/api/create-key",
      "dest": "/api/index.js",
      "methods": ["POST"]
    },
    {
      "src": "/api/keys",
      "dest": "/api/index.js",
      "methods": ["GET"]
    },
    {
      "src": "/api/revoke-key",
      "dest": "/api/index.js",
      "methods": ["DELETE"]
    }
  ],
  "headers": [
    {
      "source": "/api/(.*)",
      "headers": [
        {
          "key": "Access-Control-Allow-Origin",
          "value": "*"
        },
        {
          "key": "Access-Control-Allow-Methods",
          "value": "GET, POST, PUT, DELETE, OPTIONS"
        },
        {
          "key": "Access-Control-Allow-Headers",
          "value": "Content-Type, Authorization, X-API-Key"
        }
      ]
    }
  ]
}
