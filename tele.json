function createPayment(userId, packageDays) {
  var pkg = packages[packageDays];
  if (!pkg) return;
  
  var paymentId = Date.now() + "_" + userId;
  global.pendingPayments[userId] = {
    package: parseInt(packageDays),
    price: pkg.price,
    paymentId: paymentId,
    timestamp: Date.now()
  };
  
  Bot.sendInlineKeyboard(
    [
      [{ title: "✅ I've Made Payment", command: "/payment_done" }],
      [{ title: "❌ Cancel", command: "/start" }]
    ],
