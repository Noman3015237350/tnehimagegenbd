    "💰 Amount: " + pkg.price + " BDT\n\n" +
    "📱 *Send payment to:*\n" +
    "bKash/Nagad: `01869325625`\n\n" +
    "📝 *Steps:*\n" +
    "1. Send " + pkg.price + " BDT to the number above\n" +
    "2. Click 'I've Made Payment' button\n" +
    "3. Send transaction ID in next step\n\n" +
    "⏰ Payment ID: `" + paymentId + "`\n\n" +
    "⚠️ Key will be activated after admin confirmation.",
    "Markdown"
  );
  return;
}

