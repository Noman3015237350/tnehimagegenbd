// Check key status callback
if (request == "/check_status") {
  try {
    var result = JSON.parse(content);
    var userKey = getUserKey(user.telegramid);
    var found = false;
    var expiryDate = "";
    
    if (result.success && result.keys) {
      var userMasked = userKey.substring(0, 8) + '...' + userKey.substring(userKey.length - 4);
      
      for (var i = 0; i < result.keys.length; i++) {
        if (result.keys[i].apiKey === userMasked) {
          found = true;
          expiryDate = result.keys[i].expiresAt;
          break;
        }
      }
    }
    
    // Check local storage as backup
    if (!found && global.keyInfo && global.keyInfo[userKey]) {
      found = true;
      expiryDate = new Date(global.keyInfo[userKey].expiresAt).toISOString();
    }
    
    if (found) {
      var expiryDateObj = new Date(expiryDate);
      var daysLeft = Math.ceil((expiryDateObj - Date.now()) / (1000 * 60 * 60 * 24));
      
      Bot.sendMessage("✅ *Your API Key Status*\n\n" +
        "🔑 Status: Active\n" +
        "📅 Expires: " + expiryDateObj.toLocaleDateString() + "\n" +
        "⏰ Days Left: " + daysLeft + " days\n\n" +
        "🎨 Use /gen [prompt] to generate images!",
        "Markdown");
    } else {
      Bot.sendMessage("❌ Your API key is invalid or expired.\n\nPlease purchase a new key using /buy");
    }
  } catch(e) {
    Bot.sendMessage("❌ Error checking key status. Please try again later.");
  }
  return;
}

