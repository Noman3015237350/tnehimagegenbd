function generateAPIKey() {
  return 'xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx'.replace(/[x]/g, function() {
    return Math.random().toString(36).substr(2, 1);
  }).toUpperCase();
}

function getUserKey(telegramId) {
  if (!global.userKeys) return null;
  return global.userKeys[telegramId];
}

function saveUserKey(telegramId, apiKey) {
  if (!global.userKeys) global.userKeys = {};
  global.userKeys[telegramId] = apiKey;
}
